PORT=3000

DB_HOST=localhost
DB_PORT=5433  # Using 5433 to avoid conflict with local PostgreSQL
# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433          # 5433 avoids conflict with a local Postgres instance
DB_NAME=eduhub
DB_USER=postgres
DB_PASSWORD=yourpassword

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Optional: email notifications

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_EXPIRES_IN=7d

# ── Email (optional) ─────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=yourpassword
MAIL_FROM="EduHub <no-reply@eduhub.co.za>"
